clicker = 0
clicker_power = 1
import tkinter as tk  
root = tk.Tk()
root.title("Окно")
root.geometry("500x500")

def click():
    global clicker, clicker_power
    clicker += clicker_power
    label.config(text=f"Клики: {clicker}", font=("Arial",20))
    if clicker >= 100:
        upgrade_button.pack()

def reset():
    global clicker, clicker_power
    clicker = 0
    clicker_power = 1
    label.config(text=f"Клики: {clicker}")

button_reset = tk.Button(root, text="сброс", command=reset)
button_reset.pack()

button = tk.Button(root, text="Жми",width=30,height=3, command = click)
button.pack(expand=True)

def upgrade():
    global clicker, clicker_power
    clicker = 0
    clicker_power += 1
    label.config(text=f"Клики: {clicker}", font=("Arial",20))
    
    print("upgrade clicked")
upgrade_button = tk.Button(root, text="Улучшить", command=upgrade)
upgrade_button.pack()
upgrade_button.pack_forget()


label = tk.Label(root, text=f"Клики: {clicker}", font=("Arial",20))
label.pack(expand=True)
root.mainloop()
